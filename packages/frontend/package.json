{
  "name": "frontend",
  "version": "0.15.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test e2e/journeys/recovery-live-smoke.spec.ts",
    "test:e2e:ci": "playwright test --config=playwright.ci.config.ts",
    "test:unit": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs run",
    "test:setup": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs run --config vitest.setup.config.ts",
    "test:coverage": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs run --coverage",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@signalform/shared": "workspace:*",
    "@vueuse/core": "^14.3.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^7.0.2",
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-vue": "~10.9.2",
    "happy-dom": "^20.10.6",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxlint": "~1.73.0",
    "postcss": "^8.5.19",
    "prettier": "3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "engines": {
    "node": "^20.15.0 || >=22.12.0"
  }
}
