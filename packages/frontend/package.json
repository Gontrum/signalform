{
  "name": "frontend",
  "version": "0.9.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test e2e/journeys/recovery-live-smoke.spec.ts",
    "test:e2e:ci": "playwright test --config=playwright.ci.config.ts",
    "test:unit": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs run",
    "test:setup": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs run --config vitest.setup.config.ts",
    "test:coverage": "NODE_OPTIONS=--no-warnings node ./node_modules/vitest/vitest.mjs run --coverage",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@signalform/shared": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "lodash-es": "^4.18.1",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-oxlint": "~1.62.0",
    "eslint-plugin-vue": "~10.9.0",
    "happy-dom": "^20.9.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.62.0",
    "postcss": "^8.5.14",
    "prettier": "3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "engines": {
    "node": "^20.15.0 || >=22.12.0"
  }
}
