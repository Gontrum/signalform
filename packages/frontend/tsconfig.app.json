{
  // Extends Vue's recommended TypeScript configuration
  // - Includes "strict": true (TypeScript strict mode ENABLED)
  // - Includes "noUncheckedIndexedAccess": true (extra safety)
  // - Full compiler options: node_modules/@vue/tsconfig/tsconfig.json
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "allowImportingTsExtensions": true,

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
